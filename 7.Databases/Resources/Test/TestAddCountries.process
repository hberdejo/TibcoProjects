<?xml version="1.0" encoding="UTF-8"?>
<pd:ProcessDefinition xmlns:xsl="http://www.w3.org/1999/XSL/Transform" xmlns:pfx="http://www.tibco.com/schemas/1.Schemas/Resources/Schemas/Commons/Context" xmlns:pd="http://xmlns.tibco.com/bw/process/2003" xmlns:ns="http://www.tibco.com/schemas/1.Schemas/Resources/Schemas/SharedProcesses/WriteToFileRequest" xmlns:ns2="http://www.tibco.com/schemas/1.Schemas/Resources/Schemas/Commons/Header" xmlns:ns4="http://www.tibco.com/schemas/7.Databases/Resources/Schemas/Services/AddCountriesRequest" xmlns:ns3="http://www.tibco.com/schemas/7.Databases/Resources/Schemas/Services/GetCountriesRequest">
    <xs:import xmlns:xs="http://www.w3.org/2001/XMLSchema" namespace="http://www.tibco.com/schemas/7.Databases/Resources/Schemas/Services/GetCountriesRequest" schemaLocation="/Resources/Schemas/Services/GetCountriesRequest.xsd"/>
    <pd:name>Resources/Test/TestAddCountries.process</pd:name>
    <pd:startName>Start</pd:startName>
    <pd:startX>68</pd:startX>
    <pd:startY>90</pd:startY>
    <pd:returnBindings/>
    <pd:endName>End</pd:endName>
    <pd:endX>520</pd:endX>
    <pd:endY>79</pd:endY>
    <pd:errorSchemas/>
    <pd:processVariables/>
    <pd:targetNamespace>http://xmlns.example.com/1769708931155</pd:targetNamespace>
    <pd:activity name="AddCountries">
        <pd:type>com.tibco.pe.core.CallProcessActivity</pd:type>
        <pd:resourceType>ae.process.subprocess</pd:resourceType>
        <pd:x>277</pd:x>
        <pd:y>171</pd:y>
        <config>
            <processName>/Processes/Services/Database/AddCountries.process</processName>
        </config>
        <pd:inputBindings>
            <ns4:AddCountriesRequest>
                <ns2:Header>
                    <pfx:Context>
                        <pfx:correlationId>
                            <xsl:value-of select="'1234567'"/>
                        </pfx:correlationId>
                    </pfx:Context>
                    <ns2:timestamp>
                        <xsl:value-of select="current-dateTime()"/>
                    </ns2:timestamp>
                </ns2:Header>
                <ns4:Body>
                    <ns4:records>
                        <ns4:countryCode>
                            <xsl:value-of select="'AR'"/>
                        </ns4:countryCode>
                        <ns4:countryName>
                            <xsl:value-of select="'Argentina'"/>
                        </ns4:countryName>
                    </ns4:records>
                    <ns4:records>
                        <ns4:countryCode>
                            <xsl:value-of select="'IR'"/>
                        </ns4:countryCode>
                        <ns4:countryName>
                            <xsl:value-of select="'Israel'"/>
                        </ns4:countryName>
                    </ns4:records>
                </ns4:Body>
            </ns4:AddCountriesRequest>
        </pd:inputBindings>
    </pd:activity>
    <pd:transition>
        <pd:from>Start</pd:from>
        <pd:to>AddCountries</pd:to>
        <pd:lineType>Default</pd:lineType>
        <pd:lineColor>-16777216</pd:lineColor>
        <pd:conditionType>always</pd:conditionType>
    </pd:transition>
    <pd:transition>
        <pd:from>AddCountries</pd:from>
        <pd:to>End</pd:to>
        <pd:lineType>Default</pd:lineType>
        <pd:lineColor>-16777216</pd:lineColor>
        <pd:conditionType>always</pd:conditionType>
    </pd:transition>
</pd:ProcessDefinition>